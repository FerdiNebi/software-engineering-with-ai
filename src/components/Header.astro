---
// Custom Header override per AD-V2-2.
// Renders the top-nav strip (Process | With AI) above Starlight's
// default header (site title + search + theme/social). Active tab
// is derived from URL prefix — works without JavaScript per NFR-v2-5.

import Default from '@astrojs/starlight/components/Header.astro';

const base = import.meta.env.BASE_URL ?? '/';
// Ensure trailing slash so startsWith() does not match a prefix that
// happens to share a leading segment with /with-ai (e.g. /with-ai-foo).
const baseWithSlash = base.endsWith('/') ? base : base + '/';
const aiPrefix = baseWithSlash + 'with-ai/';
const processHref = baseWithSlash;
const isAiTree = Astro.url.pathname.startsWith(aiPrefix);
---

<nav class="top-nav" aria-label="Tree switch">
  <a
    href={processHref}
    class:list={['top-nav-link', { active: !isAiTree }]}
    aria-current={!isAiTree ? 'page' : undefined}
  >
    Process
  </a>
  <a
    href={aiPrefix}
    class:list={['top-nav-link', { active: isAiTree }]}
    aria-current={isAiTree ? 'page' : undefined}
  >
    With AI
  </a>
</nav>

<Default><slot /></Default>
